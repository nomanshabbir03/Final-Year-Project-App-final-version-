{
  "expo": {
    "name": "fyp-project-app",
    "slug": "fyp-project-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fypprojectapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow this app to use the microphone for voice commands.",
          "speechRecognitionPermission": "Allow this app to convert your speech to text for voice commands."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow this app to access your location to fetch local weather."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "googleClientIdWeb": "",
      "googleClientIdIos": "",
      "googleClientIdAndroid": "",
      "googleClientIdExpo": "",
      "apiBaseUrl": "http://127.0.0.1:8000/api"
    }
  }
}
